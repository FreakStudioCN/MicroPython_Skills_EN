{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Diagram Intermediate JSON",
  "description": "Intermediate representation of software architecture diagram + flow diagram, generated from firmware/ code and project-manifest.json, consumed by any renderer. Independent of specific tools like Mermaid/Graphviz/Visio.",
  "type": "object",
  "required": ["meta", "architecture", "flow", "data_flow"],
  "properties": {

    "meta": {
      "type": "object",
      "description": "Metadata",
      "required": ["project", "mode", "generated_at", "source_phase"],
      "properties": {
        "project": { "type": "string", "description": "Project name" },
        "mode": { "type": "string", "enum": ["timer", "asyncio", "thread"], "description": "Scheduling mode" },
        "generated_at": { "type": "string", "description": "ISO 8601 timestamp" },
        "source_phase": { "type": "string", "enum": ["scaffold", "generate"], "description": "From which phase's code it was generated" },
        "mcu": { "type": "string", "description": "MCU model" }
      }
    },

    "architecture": {
      "type": "object",
      "description": "Layered architecture dependency graph",
      "required": ["layers"],
      "properties": {
        "layers": {
          "type": "array",
          "description": "Arranged by architecture layer (bottom-up: Board → Library → Driver → Task → Entry)",
          "items": {
            "type": "object",
            "required": ["id", "label", "modules"],
            "properties": {
              "id": {
                "type": "string",
                "enum": ["board", "lib", "driver", "task", "entry", "host", "test"],
                "description": "Layer ID, determines rendering order and color"
              },
              "label": {
                "type": "string",
                "description": "Chinese label of the layer, e.g., Board Layer"
              },
              "color": {
                "type": "string",
                "description": "Suggested rendering color (hex), can be overridden by renderer"
              },
              "modules": {
                "type": "array",
                "description": "Modules contained in this layer",
                "items": {
                  "type": "object",
                  "required": ["name", "path", "provides", "depends_on"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Module name (Python import path), e.g., tasks.sensor_task"
                    },
                    "path": {
                      "type": "string",
                      "description": "File path relative to project root, e.g., firmware/tasks/sensor_task.py"
                    },
                    "role": {
                      "type": "string",
                      "description": "Chinese description of module responsibility, extracted from first line of docstring or supplemented by LLM"
                    },
                    "provides": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "List of externally exported symbols (function/class names)"
                    },
                    "depends_on": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "List of dependent module names (Python import paths)"
                    },
                    "depends_on_machine": {
                      "type": "boolean",
                      "default": false,
                      "description": "Whether it directly depends on the machine module (i.e., imports machine.Pin/I2C/SPI, etc.)"
                    },
                    "has_mock": {
                      "type": "boolean",
                      "default": false,
                      "description": "Whether there is a corresponding mock implementation"
                    },
                    "is_generated": {
                      "type": "boolean",
                      "default": false,
                      "description": "Whether it was automatically generated by upy-generate"
                    },
                    "is_template": {
                      "type": "boolean",
                      "default": false,
                      "description": "Whether it comes from the scaffold template library (not generated, not driver source code)"
                    },
                    "source": {
                      "type": "string",
                      "enum": ["scaffold_template", "llm_generated", "upypi_download", "github_download", "cold_driver", "user_custom"],
                      "description": "Module source"
                    }
                  }
                }
              }
            }
          }
        },
        "cross_layer_deps": {
          "type": "array",
          "description": "Cross-layer dependency relationships (deduplicated depends_on set)",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": "string", "description": "Optional edge label" },
              "style": { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "solid" }
            }
          }
        }
      }
    },

    "flow": {
      "type": "array",
      "description": "Sequence of steps in the main.py execution flow",
      "items": {
        "type": "object",
        "required": ["seq", "phase", "action"],
        "properties": {
          "seq": {
            "type": "integer",
            "description": "Step sequence number (starting from 1)"
          },
          "phase": {
            "type": "string",
            "enum": ["boot", "init", "scan", "create", "assembly", "run", "shutdown"],
            "description": "Phase to which the step belongs"
          },
          "action": {
            "type": "string",
            "description": "Action description (short Chinese title)"
          },
          "detail": {
            "type": "string",
            "description": "Action details, such as specific parameter values, I2C address, etc."
          },
          "source_line": {
            "type": "integer",
            "description": "Line number in main.py, renderer can use to generate source code links"
          },
          "depends_on_step": {
            "type": "integer",
            "description": "Prerequisite step seq that this step depends on (for dependency arrows in flow diagram)"
          },
          "on_error": {
            "type": "string",
            "enum": ["fatal", "skip_device", "retry", "degrade"],
            "description": "Handling strategy when this step fails"
          },
          "is_conditional": {
            "type": "boolean",
            "default": false,
            "description": "Whether it is a conditional branch (e.g., if scan success → create else → skip)"
          },
          "branches": {
            "type": "array",
            "description": "Description of conditional branches (used when is_conditional=true)",
            "items": {
              "type": "object",
              "properties": {
                "condition": { "type": "string" },
                "goto_step": { "type": "integer" }
              }
            }
          }
        }
      }
    },

    "data_flow": {
      "type": "array",
      "description": "Data flow between modules",
      "items": {
        "type": "object",
        "required": ["from", "to", "data"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Data source (function name, variable name, or module name)"
          },
          "to": {
            "type": "string",
            "description": "Data destination"
          },
          "data": {
            "type": "string",
            "description": "Description of the transmitted data"
          },
          "channel": {
            "type": "string",
            "enum": ["function_return", "shared_dict", "global_var", "queue", "callback_param"],
            "default": "shared_dict",
            "description": "Type of data transmission channel"
          },
          "rate": {
            "type": "string",
            "description": "Data refresh rate, e.g., 1Hz, on_change"
          }
        }
      }
    },

    "task_registry": {
      "type": "array",
      "description": "Scheduler task registration list (extracted from main.py)",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Task name" },
          "callback": { "type": "string", "description": "Callback function name" },
          "interval_ms": { "type": "integer", "description": "Execution interval (milliseconds)" },
          "mode": { "type": "string", "enum": ["periodic", "once", "on_event"], "default": "periodic" }
        }
      }
    },

    "diagnostics": {
      "type": "object",
      "description": "Code structure diagnostic information (for review reference, not required for rendering)",
      "properties": {
        "total_modules": { "type": "integer" },
        "total_dependencies": { "type": "integer" },
        "max_depth": { "type": "integer", "description": "Maximum depth of dependency graph" },
        "circular_deps": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" } },
          "description": "Detected circular dependencies (should be empty)"
        },
        "orphan_modules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Modules not depended on by any other module"
        },
        "machine_direct_access": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Modules that directly import machine (should warn except for main.py)"
        }
      }
    }

  }
}
