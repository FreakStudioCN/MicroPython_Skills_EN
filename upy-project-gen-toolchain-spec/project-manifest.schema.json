{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Manifest",
  "description": "One-sentence hardware project manifest, progressively filled in each phase. Each Phase only writes its own fields.",
  "type": "object",
  "required": ["schema_version", "phase", "created_at", "project_name", "requirements", "devices"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Manifest schema version"
    },
    "phase": {
      "type": "string",
      "enum": ["analyze", "select-hw", "scaffold", "generate",
               "wiring", "diagram", "deploy", "autofix",
               "cold-driver", "simulate", "complete", "failed"],
      "description": "Current phase"
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp, project creation time"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp, last modification time"
    },
    "project_name": {
      "type": "string",
      "description": "Project name, extracted by LLM from user description"
    },

    "requirements": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Chinese summary of the user's original requirements"
        },
        "description_en": {
          "type": "string",
          "description": "English summary for search keywords"
        },
        "scene": {
          "type": "string",
          "enum": ["indoor", "outdoor", "vehicle", "industrial", "wearable", "underwater", "unknown"],
          "default": "indoor"
        },
        "power": {
          "type": "string",
          "enum": ["usb", "battery_li", "battery_disposable", "solar", "poe", "unknown"],
          "default": "usb"
        },
        "network": {
          "type": "string",
          "enum": ["none", "wifi", "ble", "mqtt", "zigbee", "lora", "4g", "unknown"],
          "default": "none"
        },
        "sample_rate": {
          "type": "string",
          "enum": ["high_100hz_plus", "normal_1hz", "low_minute", "triggered", "unknown"],
          "default": "normal_1hz"
        },
        "precision": {
          "type": "string",
          "enum": ["high", "normal", "low_power_first", "unknown"],
          "default": "normal"
        },
        "response_time": {
          "type": "string",
          "enum": ["ms_level", "1s", "minute_level", "unknown"],
          "default": "1s"
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["serial", "display_oled", "display_lcd", "display_eink",
                     "buzzer", "led", "led_rgb", "cloud_mqtt", "cloud_http",
                     "local_file", "relay", "motor", "servo"]
          },
          "default": ["serial"],
          "description": "List of output methods"
        },
        "temp_range": {
          "type": "string",
          "enum": ["normal_0_40", "extended_-20_70", "industrial_-40_85", "unknown"],
          "default": "normal_0_40"
        },
        "size_constraint": {
          "type": "string",
          "enum": ["none", "compact", "wearable", "custom", "unknown"],
          "default": "none"
        },
        "budget_yuan": {
          "type": "string",
          "enum": ["low_30", "medium_50", "medium_100", "high_200", "unlimited", "unknown"],
          "default": "medium_50"
        },
        "existing_hardware": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "List of user's existing hardware (model or generic name)"
        },
        "experience": {
          "type": "string",
          "enum": ["beginner", "experienced", "unknown"],
          "default": "beginner"
        },
        "special_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["watchdog", "ota_update", "deep_sleep", "encryption", "button_control", "voice_control", "battery_monitor", "error_led", "none"]
          },
          "default": ["none"],
          "description": "Special functional requirements"
        },
        "mcu_specified": {
          "type": "string",
          "description": "User-specified MCU model (null if not specified)"
        }
      }
    },

    "devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "interface"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Device model, e.g., SHT30, INMP441"
          },
          "type": {
            "type": "string",
            "description": "Device category: temperature_sensor, humidity_sensor, imu, microphone, speaker, display, led, button, relay, motor, servo, rtc, storage, other"
          },
          "interface": {
            "type": "string",
            "enum": ["I2C", "SPI", "UART", "GPIO", "PWM", "ADC", "I2S", "1-Wire", "CAN", "USB", "WiFi", "BLE"],
            "description": "Communication interface type"
          },
          "i2c_addr": {
            "type": "array",
            "items": {"type": "string", "pattern": "^0x[0-9a-fA-F]{2}$"},
            "description": "I2C address list (required for I2C devices)"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "notes": {
            "type": "string",
            "description": "Supplementary notes (power consumption, special requirements, etc.)"
          },
          "driver": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": ["builtin_runtime", "micropython_lib", "upypi", "awesome-micropython", "github", "local", "cold-driver", "none"],
                "description": "Driver source"
              },
              "package_name": {"type": "string"},
              "version": {"type": "string"},
              "url": {"type": "string", "format": "uri"},
              "install_cmd": {"type": "string"},
              "api_ref": {
                "type": "object",
                "description": "API usage key points obtained from upy-pkg-guide (constructor, core methods, notes)"
              }
            }
          }
        }
      }
    },

    "mcu": {
      "type": "object",
      "description": "[Phase 2] MCU selection result",
      "properties": {
        "model": {"type": "string"},
        "board": {"type": "string"},
        "reason": {"type": "string"},
        "specs": {"type": "object"}
      }
    },

    "bom": {
      "type": "array",
      "description": "[Phase 2] BOM bill of materials",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "model": {"type": "string"},
          "quantity": {"type": "integer"},
          "unit_price_yuan": {"type": "number"},
          "notes": {"type": "string"}
        }
      }
    },

    "pinout": {
      "type": "array",
      "description": "[Phase 2] Pin assignment table",
      "items": {
        "type": "object",
        "properties": {
          "device": {"type": "string"},
          "pin_name": {"type": "string"},
          "gpio": {"type": "string"},
          "mcu_pin": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },

    "scheduler_type": {
      "type": "string",
      "enum": ["timer", "asyncio", "while_loop", "multi_thread"],
      "description": "[Phase 3] Scheduler type"
    },

    "file_structure": {
      "type": "object",
      "description": "[Phase 3] Generated file structure"
    },

    "generated_files": {
      "type": "array",
      "description": "[Phase 4] List of generated code files",
      "items": {"type": "object"}
    },

    "static_check": {
      "type": "object",
      "description": "[Phase 4] black/flake8 check results"
    },

    "doc_check": {
      "type": "object",
      "description": "[Phase 5] MPY API documentation verification results",
      "properties": {
        "passed": {"type": "boolean"},
        "issues": {"type": "array"},
        "suggestions": {"type": "array"}
      }
    },

    "injection": {
      "type": "object",
      "description": "[Phase 6] Test point injection results"
    },

    "unittest_files": {
      "type": "array",
      "description": "[Phase 6] Generated unittest files",
      "items": {"type": "string"}
    },

    "wiring": {
      "type": "object",
      "description": "[Phase 7a] Wiring diagram generation results",
      "properties": {
        "wiring_png": {"type": "string"},
        "wiring_md": {"type": "string"}
      }
    },

    "diagrams": {
      "type": "object",
      "description": "[Phase 7b] Architecture diagram and flowchart generation results",
      "properties": {
        "architecture_md": {"type": "string"},
        "flowchart_md": {"type": "string"}
      }
    },

    "deploy": {
      "type": "object",
      "description": "[Phase 8] Deployment results",
      "properties": {
        "com_port": {"type": "string"},
        "files_uploaded": {"type": "integer"},
        "verified": {"type": "boolean"},
        "output_summary": {"type": "string"},
        "exit_code": {"type": "integer"}
      }
    },

    "fix_attempts": {
      "type": "array",
      "description": "[Phase 9] Auto-fix attempt records",
      "items": {
        "type": "object",
        "properties": {
          "attempt": {"type": "integer"},
          "error_type": {"type": "string"},
          "strategy": {"type": "string"},
          "result": {"type": "string"},
          "commit_hash": {"type": "string"}
        }
      }
    },

    "final_status": {
      "type": "string",
      "enum": ["pass", "fail_software", "fail_hardware", "fail_cold_driver", "pending"],
      "default": "pending",
      "description": "Final status"
    },

    "error_report": {
      "type": "object",
      "description": "[Phase 9] Error report (written on failure)"
    }
  }
}
