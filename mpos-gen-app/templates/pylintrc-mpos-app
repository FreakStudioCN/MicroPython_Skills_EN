[MASTER]
persistent=no

[MESSAGES CONTROL]
disable=
    import-error,
    no-member,
    no-name-in-module,
    c-extension-no-member,
    missing-module-docstring,
    missing-function-docstring,
    missing-class-docstring,
    broad-exception-caught,
    too-few-public-methods,
    duplicate-code,
    consider-using-f-string,
    import-outside-toplevel,
    invalid-name,
    unused-variable,
    ungrouped-imports,
    line-too-long,
    trailing-whitespace,
    trailing-newlines,
    missing-final-newline,
    attribute-defined-outside-init,
    unused-argument,
    wrong-import-order,
    wrong-import-position,
    protected-access,
    too-many-instance-attributes,
    too-many-locals,
    too-many-statements,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-public-methods,
    too-many-lines,
    superfluous-parens,
    expression-not-assigned,
    reimported,
    fixme,
    pointless-string-statement,
    unspecified-encoding,
    f-string-without-interpolation,
    multiple-statements,
    unnecessary-semicolon,
    bare-except,
    raise-missing-from,
    no-else-return,
    too-many-branches,
    too-many-return-statements,
    no-else-break,
    chained-comparison,
    consider-using-enumerate,
    consider-using-in,
    consider-using-with,
    consider-using-max-builtin,
    consider-using-min-builtin,
    consider-using-dict-items,
    consider-iterating-dictionary,
    unnecessary-comprehension,
    unnecessary-negation,
    useless-return,
    useless-parent-delegation,
    disallowed-name,
    using-constant-test,
    singleton-comparison,
    wildcard-import,
    unused-wildcard-import,
    redefined-outer-name,
    undefined-loop-variable,
    cell-var-from-loop,
    arguments-differ,
    bad-indentation,
    unreachable

[BASIC]
additional-builtins=
    const,
    micropython,
    ptr,
    ptr8,
    ptr16,
    ptr32,
    uint,
    int8,
    int16,
    int32,
    mem8,
    mem16,
    mem32,
    asm_pio,
    wrap_target,
    wrap,
    label,
    word,
    jmp,
    irq,
    out,
    in_,
    push,
    pull,
    mov,
    set,
    wait,
    nop,
    side

[TYPECHECK]
ignored-modules=
    lvgl,mpos,machine,micropython,pyb,esp,esp32,espnow,rp2,mimxrt,zephyr,wipy,stm,
    neopixel,network,bluetooth,framebuf,uctypes,cryptolib,deflate,btree,
    vfs,openamp,lcd160cr,WM8960,
    uasyncio,uselect,utime,ujson,uos,ustruct,ure,uzlib,uhashlib,
    ubinascii,ucollections,urandom,uerrno,uheapq,ussl,usocket,
    webcam,pdm_mic,adc_mic,qrdecode

[FORMAT]
max-line-length=120

[REPORTS]
reports=no
score=no
